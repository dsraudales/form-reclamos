# -------------------------------------------------------------
# Variables de entorno para Vercel + Supabase
# Copia estas claves en Vercel (Project Settings -> Environment Variables)
# y en un archivo .env.local para desarrollo y migraciones.
# No subas valores reales al repositorio.
# -------------------------------------------------------------

NODE_ENV=production

# URL publica del despliegue (sin barra final). En Vercel suele ser el dominio final.
NEXTAUTH_URL=https://tu-proyecto.vercel.app
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET=

# Login local de administradores (correo + contrasena con bcrypt)
# Ya no hace falta duplicar flags con NEXT_PUBLIC_* para mostrar el login.
ENABLE_LOCAL_LOGIN=true

# Base de datos: Supabase Postgres
# DATABASE_URL = pooler / transaction mode para la app en serverless.
#   Debe incluir: ?pgbouncer=true&connection_limit=1
# DIRECT_URL = conexion directa para Prisma migrate.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.<ref>:<password>@db.<ref>.supabase.co:5432/postgres

# Storage de fotos: Supabase Storage
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=cree-client-photos

# Rate limiting: Upstash Redis (opcional)
# Si no defines estas variables, la app usa un fallback en memoria.
# En Vercel ese fallback es por instancia, asi que Upstash sigue siendo recomendado.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
PUBLIC_SUBMISSION_RATE_LIMIT=12
LOCAL_LOGIN_RATE_LIMIT=10

# Secreto para hashear IPs en auditoria.
# Genera con: openssl rand -hex 32
# Si lo omites, la app reutiliza NEXTAUTH_SECRET.
IP_HASH_SECRET=

# Antivirus (ClamAV): desactivado en Vercel serverless
CLAMAV_ENABLED=false

# Login Microsoft Entra (Azure AD): opcional
# AZURE_AD_CLIENT_ID=
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_SECRET=

# Semilla del admin inicial (solo para seed local)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
