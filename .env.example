# ─────────────────────────────────────────────────────────────
# Variables de entorno para Vercel + Supabase + Upstash
# Copia estas claves en Vercel (Project Settings → Environment Variables)
# y en un archivo .env.local para desarrollo / migraciones locales.
# NO subas valores reales al repositorio.
# ─────────────────────────────────────────────────────────────

NODE_ENV=production

# URL pública del despliegue (sin barra final). En Vercel suele ser el dominio de producción.
NEXTAUTH_URL=https://tu-proyecto.vercel.app
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET=

# Login local de administradores (correo + contraseña con bcrypt)
ENABLE_LOCAL_LOGIN=true
NEXT_PUBLIC_ENABLE_LOCAL_LOGIN=true
NEXT_PUBLIC_ENABLE_ENTRA_LOGIN=false

# ── Base de datos: Supabase Postgres ──────────────────────────
# DATABASE_URL = conexión "pooler" (PgBouncer, puerto 6543) para la app en serverless.
#   Debe incluir: ?pgbouncer=true&connection_limit=1
# DIRECT_URL  = conexión directa (puerto 5432) que usa Prisma SOLO para migraciones.
# Las obtienes en Supabase → Project Settings → Database → Connection string.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Almacenamiento de fotos: Supabase Storage ─────────────────
# SUPABASE_URL = Project URL (Settings → API).
# SUPABASE_SERVICE_ROLE_KEY = clave service_role (Settings → API). SECRETA, solo backend.
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=cree-client-photos

# ── Rate limiting: Upstash Redis (REST) ───────────────────────
# Crea una base Redis gratis en https://upstash.com y copia las credenciales REST.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
PUBLIC_SUBMISSION_RATE_LIMIT=12
LOCAL_LOGIN_RATE_LIMIT=10

# Secreto para hashear IPs en auditoría. Genera con: openssl rand -hex 32
IP_HASH_SECRET=

# ── Antivirus (ClamAV): NO disponible en Vercel serverless ────
# Mantener desactivado. El código omite el escaneo cuando es "false".
CLAMAV_ENABLED=false

# ── Login Microsoft Entra (Azure AD): opcional, desactivado ───
# AZURE_AD_CLIENT_ID=
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_SECRET=

# ── Semilla del admin inicial (solo para correr el seed local) ─
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
