NODE_ENV=production
NEXTAUTH_URL=https://reclamos.example.hn
NEXTAUTH_SECRET=

# Supabase PostgreSQL connection string
DATABASE_URL=

# Supabase project URL and service role key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=client-photos

# Rate limiting
PUBLIC_SUBMISSION_RATE_LIMIT=12
LOCAL_LOGIN_RATE_LIMIT=10
IP_HASH_SECRET=

# Authentication
ENABLE_LOCAL_LOGIN=true
NEXT_PUBLIC_ENABLE_LOCAL_LOGIN=true
NEXT_PUBLIC_ENABLE_ENTRA_LOGIN=false

# Azure AD / Entra ID (optional)
AZURE_AD_CLIENT_ID=
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_SECRET=

# Local seed only. Do not commit real values.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
